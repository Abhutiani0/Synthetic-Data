# Copy to .env and fill in. NEVER commit the real .env.

# Database (SQLite for local MVP). Use a postgresql:// URL to switch later.
DATABASE_URL=sqlite:///./storage/verisynth.db

# Where uploaded files and generated CSVs are stored
STORAGE_PATH=./storage

# Optional. If unset, the app uses the built-in deterministic report writer.
# Only schema + statistical summaries are ever sent to OpenAI, never raw rows.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000
